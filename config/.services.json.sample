{
  "flussu":{
    "version":"5.0",
    "release":"20251103"
  },
  "services": {
    "google":{
      "type": "service_account",
      "project_id": "your-project-name",
      "private_key_id": "your-private-key-id-here",
      "private_key": "-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n",
      "client_email": "your-service-account@your-project.iam.gserviceaccount.com",
      "client_id": "000000000000000000000",
      "auth_uri": "https://accounts.google.com/o/oauth2/auth",
      "token_uri": "https://oauth2.googleapis.com/token",
      "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
      "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com",
      "universe_domain": "googleapis.com",
      "drive_config": {
        "mode": "service_account_folder",
        "share_with": [
          {
            "email": "user@example.com",
            "role": "writer"
          }
        ]
      }
    },
    "sms_provider":{
      "default":"JomobileSms",
      "JomobileSms":{
        "api_key":"your-jomobile-api-key-here",
        "method":"get"
      },
      "ovh_sms":{
        "api_key":"your-ovh-sms-api-key-here",
        "method":"post"
      },
      "SmsFactor":{
        "api_key":"your-smsfactor-jwt-token-here",
        "method":"post"
      }
    },
    "shorturl":{
      "default":"flu_lu",
      "flu_lu":{
        "api_key":"your-shorturl-api-key-here",
        "uri":"flu.lu",
        "method":"get"
      }
    },
    "email":{
      "default":"ovh",
      "ovh":{
        "smtp_host":"pro1.mail.ovh.net",
        "smtp_user":"noreply@yourdomain.com",
        "smtp_pass":"your-smtp-password-here",
        "smtp_port":"587",
        "smtp_encrypt":"TLS",
        "smtp_auth":"1"
      },
      "ovh_ssl0":{
        "smtp_host":"ssl0.ovh.net",
        "smtp_user":"dontreply@yourdomain.com",
        "smtp_pass":"your-smtp-password-here",
        "smtp_port":"587",
        "smtp_encrypt":"TLS",
        "smtp_auth":"1"
      }
    },
    "pay_provider":{
      "stripe":{
        "your_account_name":{
          "prod":"sk_prod_your-stripe-production-key-here",
          "test":"sk_test_your-stripe-test-key-here",
          "method":"post"
        }
      },
      "revolut":{
        "your_account_name":{
          "prod":"rvk_prod_your-revolut-production-key-here",
          "test":"rvk_test_your-revolut-test-key-here",
          "method":"post"
        }
      }
    },
    "ai_provider":{
      "default_temperature": 0.7,
      "service_model":"mistral",
      "open_ai":{
        "auth_key":"sk-proj-your-openai-api-key-here",
        "model":"gpt-5-nano",
        "chat-model":"gpt-4o-mini",
        "image-model":"gpt-image-1",
        "default_temperature": 0.7
      },
      "xai_grok":{
        "auth_key":"xai-your-grok-api-key-here",
        "model":"grok-4-fast-non-reasoning",
        "chat-model":"grok-4-fast-non-reasoning",
        "image-model":"grok-imagine-image",
        "default_temperature": 0.7
      },
      "ggl_gemini":{
        "auth_key":"your-gemini-api-key-here",
        "model":"gemini-3-flash-preview",
        "chat-model":"gemini-3-flash-preview",
        "image-model":"gemini-2.5-flash-image",
        "default_temperature": 0.7
      },
      "deepseek":{
        "auth_key":"sk-your-deepseek-api-key-here",
        "model":"deepseek-chat",
        "chat-model":"deepseek-chat",
        "default_temperature": 1.3
      },
      "ant_claude":{
        "auth_key":"sk-ant-your-anthropic-api-key-here",
        "model":"claude-haiku-4-5",
        "chat-model":"claude-haiku-4-5",
        "default_temperature": 0.7
      },
      "zeroone_ai":{
        "auth_key":"your-01ai-api-key-here",
        "model":"yi-lightning",
        "chat-model":"yi-lightning",
        "default_temperature": 0.7
      },
      "kimi":{
        "auth_key":"sk-your-kimi-api-key-here",
        "model":"kimi-k2-0905-preview",
        "chat-model":"kimi-k2-0905-preview",
        "default_temperature": 0.3
      },
      "qwen":{
        "auth_key":"sk-your-dashscope-api-key-here",
        "model":"qwen-turbo",
        "chat-model":"qwen-turbo",
        "image-model":"wan2.2-t2i-flash",
        "default_temperature": 0.7
      },
      "huggingface":{
        "auth_token":"hf-your-huggingface-token-here",
        "model":"Helsinki-NLP/opus-mt-it-en",
        "default_temperature": 0.7
      },
      "moonshot":{
        "auth_key":"sk-your-moonshot-api-key-here",
        "model":"moonshot-v1-8k",
        "chat-model":"moonshot-v1-8k",
        "default_temperature": 0.3
      },
      "stability_ai":{
        "auth_key":"sk-your-stability-ai-key-here",
        "model":"sd3.5-large"
      },
      "mistral":{
        "auth_key":"sk-insert-your-mistral-api-key",
        "model":"mistral-large-latest",
        "chat-model":"mistral-large-latest",
        "default_temperature": 0.7
      },
      "zai_glm":{
        "auth_key":"sk-your-zai-api-key-here",
        "model":"glm-4.5v",
        "chat-model":"glm-4.6",
        "image-model":"cogView-4-250304",
        "default_temperature": 0.6
      },
      "together":{
        "auth_key":"your-together-api-key-here",
        "model":"meta-llama/Llama-3.3-70B-Instruct-Turbo",
        "chat-model":"meta-llama/Llama-3.3-70B-Instruct-Turbo",
        "image-model":"black-forest-labs/FLUX.1-schnell",
        "default_temperature": 0.7
      }
    },
    "web_research":{
      "default_lang":"it",
      "default_geo":"it",
      "top_results":5,
      "deep_fetch":1,
      "deep_fetch_format":"markdown",
      "deep_fetch_max_chars":12000,
      "per_request_timeout_sec":12,
      "prefer_native_provider_tool":true,
      "engines":["duckduckgo","brave","searx","startpage","presearch"]
    }
  },
  "webhooks":{
    "zapier":{
      "sign":["Zapier"],
      "call":"ZapierController@apicall",
      "credentials": [
        {
          "username": "zapier_user",
          "password": "your_secure_password_here",
          "user_id": 16,
          "comment": "Password can be plain text or bcrypt hash (starts with $2y$). Use: password_hash('your_password', PASSWORD_BCRYPT)"
        }
      ]
    },
    "ifttt":{
      "sign":["IFTTT"],
      "call":"IftttController@apiCall",
      "credentials": [
        {
          "username": "ifttt",
          "password": "your_ifttt_service_key_here",
          "user_id": 16,
          "comment": "This is your IFTTT service key. Can also use bcrypt hash for security."
        }
      ]
    },
    "stripe":{
      "sign":["Stripe/","//stripe.com/"],
      "call":"StripeController@webhook"
    },
    "revolut":{
      "sign":["Revolut ","revolut "],
      "call":"RevolutController@webhook"
    }
  }
}
